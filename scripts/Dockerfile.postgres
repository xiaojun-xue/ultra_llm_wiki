# Custom PostgreSQL with pgvector + pg_jieba for Chinese full-text search
FROM pgvector/pgvector:pg16

# Install build dependencies for pg_jieba
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    cmake \
    git \
    postgresql-server-dev-16 \
    && rm -rf /var/lib/apt/lists/*

# Build and install pg_jieba
RUN git clone --depth 1 https://github.com/jaiminpan/pg_jieba.git /tmp/pg_jieba \
    && cd /tmp/pg_jieba \
    && git submodule update --init --recursive \
    && mkdir build && cd build \
    && cmake .. \
    && make && make install \
    && rm -rf /tmp/pg_jieba

# Clean up build deps
RUN apt-get purge -y build-essential cmake git postgresql-server-dev-16 \
    && apt-get autoremove -y \
    && rm -rf /var/lib/apt/lists/*
